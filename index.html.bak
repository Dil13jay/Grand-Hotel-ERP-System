<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Grand Hotel ERP Room Management Module" />
  <title>Room Management | Grand Hotel ERP</title>

  <link rel="preconnect" href="https://cdn.jsdelivr.net" />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="css/style.css" />
</head>

<body>
  <div class="app-shell">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-brand">
        <img
          src="assets/grand-hotel-mark.jpg"
          alt="Grand Hotel logo"
          class="brand-mark"
        />
        <div>
          <div class="brand-name">GRAND HOTEL</div>
          <div class="brand-subtitle">ERP SYSTEM</div>
        </div>
      </div>

      <nav class="sidebar-nav" aria-label="Main navigation">
        <a href="#" class="nav-item">
          <i class="bi bi-grid-1x2-fill"></i>
          <span>Dashboard</span>
        </a>
        <a href="#" class="nav-item">
          <i class="bi bi-calendar-check"></i>
          <span>Reservations</span>
        </a>
        <a href="#" class="nav-item active" aria-current="page">
          <i class="bi bi-door-open-fill"></i>
          <span>Room Management</span>
        </a>
        <a href="#" class="nav-item">
          <i class="bi bi-receipt-cutoff"></i>
          <span>Billing & Payments</span>
        </a>
        <a href="#" class="nav-item">
          <i class="bi bi-people-fill"></i>
          <span>Employees</span>
        </a>
        <a href="#" class="nav-item">
          <i class="bi bi-box-seam-fill"></i>
          <span>Inventory</span>
        </a>
        <a href="#" class="nav-item">
          <i class="bi bi-bar-chart-line-fill"></i>
          <span>Reports</span>
        </a>

        <div class="nav-section-label">SYSTEM</div>

        <a href="#" class="nav-item">
          <i class="bi bi-gear-fill"></i>
          <span>Settings</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="mini-profile">
          <div class="avatar">HM</div>
          <div class="profile-text">
            <strong>Hotel Manager</strong>
            <small>Administrator</small>
          </div>
          <button class="icon-btn sidebar-more" aria-label="More options">
            <i class="bi bi-three-dots-vertical"></i>
          </button>
        </div>
      </div>
    </aside>

    <!-- Main area -->
    <div class="main-area">
      <header class="topbar">
        <div class="d-flex align-items-center gap-3">
          <button
            class="icon-btn menu-toggle"
            id="menuToggle"
            type="button"
            aria-label="Toggle sidebar"
          >
            <i class="bi bi-list"></i>
          </button>

          <div class="page-heading">
            <h1>Room Management</h1>
            <p>Monitor room availability, conditions and housekeeping status.</p>
          </div>
        </div>

        <div class="topbar-actions">
          <div class="search-box d-none d-lg-flex">
            <i class="bi bi-search"></i>
            <input
              type="search"
              id="globalSearch"
              placeholder="Search room number or type..."
              aria-label="Search rooms"
            />
          </div>

          <button class="icon-btn notification-btn" aria-label="Notifications">
            <i class="bi bi-bell"></i>
            <span class="notification-dot"></span>
          </button>

          <div class="top-profile">
            <div class="avatar avatar-light">HM</div>
            <div class="d-none d-md-block">
              <strong>Hotel Manager</strong>
              <small>Admin</small>
            </div>
            <i class="bi bi-chevron-down d-none d-md-inline"></i>
          </div>
        </div>
      </header>

      <main class="content">
        <section class="welcome-banner">
          <div>
            <span class="eyebrow">GRAND HOTEL ERP</span>
            <h2>Room operations at a glance</h2>
            <p>
              Keep availability accurate, assign housekeeping priorities and
              update room conditions from one place.
            </p>
          </div>

          <div class="banner-actions">
            <button class="btn btn-outline-gold" id="resetDataBtn" type="button">
              <i class="bi bi-arrow-counterclockwise"></i>
              Reset Demo Data
            </button>
            <button
              class="btn btn-gold"
              type="button"
              data-bs-toggle="modal"
              data-bs-target="#roomModal"
              id="openAddRoom"
            >
              <i class="bi bi-plus-lg"></i>
              Add New Room
            </button>
          </div>
        </section>

        <!-- Summary cards -->
        <section class="stats-grid" aria-label="Room statistics">
          <article class="stat-card">
            <div class="stat-icon total">
              <i class="bi bi-building"></i>
            </div>
            <div>
              <span>Total Rooms</span>
              <strong id="totalRooms">0</strong>
              <small>Registered in system</small>
            </div>
          </article>

          <article class="stat-card">
            <div class="stat-icon available">
              <i class="bi bi-check-circle-fill"></i>
            </div>
            <div>
              <span>Available</span>
              <strong id="availableRooms">0</strong>
              <small>Ready for reservation</small>
            </div>
          </article>

          <article class="stat-card">
            <div class="stat-icon occupied">
              <i class="bi bi-person-check-fill"></i>
            </div>
            <div>
              <span>Occupied</span>
              <strong id="occupiedRooms">0</strong>
              <small>Currently assigned</small>
            </div>
          </article>

          <article class="stat-card">
            <div class="stat-icon cleaning">
              <i class="bi bi-stars"></i>
            </div>
            <div>
              <span>Needs Attention</span>
              <strong id="attentionRooms">0</strong>
              <small>Cleaning or maintenance</small>
            </div>
          </article>
        </section>

        <!-- Main management card -->
        <section class="management-card">
          <div class="management-header">
            <div>
              <h3>Rooms Directory</h3>
              <p>View and update room information and operational status.</p>
            </div>

            <div class="view-switcher" role="group" aria-label="View options">
              <button class="view-btn active" id="tableViewBtn" type="button">
                <i class="bi bi-list-ul"></i>
              </button>
              <button class="view-btn" id="cardViewBtn" type="button">
                <i class="bi bi-grid-3x3-gap"></i>
              </button>
            </div>
          </div>

          <div class="filter-bar">
            <div class="mobile-search d-lg-none">
              <i class="bi bi-search"></i>
              <input
                type="search"
                id="mobileSearch"
                placeholder="Search rooms..."
                aria-label="Search rooms"
              />
            </div>

            <div class="filter-group">
              <label for="statusFilter">Status</label>
              <select id="statusFilter" class="form-select">
                <option value="All">All statuses</option>
                <option value="Available">Available</option>
                <option value="Occupied">Occupied</option>
                <option value="Reserved">Reserved</option>
                <option value="Cleaning">Cleaning</option>
                <option value="Maintenance">Maintenance</option>
              </select>
            </div>

            <div class="filter-group">
              <label for="typeFilter">Room Type</label>
              <select id="typeFilter" class="form-select">
                <option value="All">All room types</option>
                <option value="Standard">Standard</option>
                <option value="Deluxe">Deluxe</option>
                <option value="Suite">Suite</option>
                <option value="Family">Family</option>
              </select>
            </div>

            <div class="filter-group">
              <label for="floorFilter">Floor</label>
              <select id="floorFilter" class="form-select">
                <option value="All">All floors</option>
                <option value="1">Floor 1</option>
                <option value="2">Floor 2</option>
                <option value="3">Floor 3</option>
                <option value="4">Floor 4</option>
              </select>
            </div>

            <button class="btn clear-filter-btn" id="clearFilters" type="button">
              <i class="bi bi-x-circle"></i>
              Clear
            </button>
          </div>

          <!-- Table view -->
          <div class="table-responsive room-table-wrap" id="tableView">
            <table class="table room-table align-middle">
              <thead>
                <tr>
                  <th>Room</th>
                  <th>Type</th>
                  <th>Floor</th>
                  <th>Capacity</th>
                  <th>Rate / Night</th>
                  <th>Status</th>
                  <th>Condition</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody id="roomTableBody"></tbody>
            </table>
          </div>

          <!-- Card view -->
          <div class="room-card-grid d-none" id="cardView"></div>

          <div class="empty-state d-none" id="emptyState">
            <i class="bi bi-door-closed"></i>
            <h4>No rooms found</h4>
            <p>Try changing the search term or selected filters.</p>
          </div>

          <div class="management-footer">
            <span id="resultCount">Showing 0 rooms</span>
            <span class="last-updated">
              <i class="bi bi-clock-history"></i>
              Last updated: <span id="lastUpdated">Just now</span>
            </span>
          </div>
        </section>
      </main>

      <footer class="app-footer">
        <span>© 2026 Grand Hotel ERP. All rights reserved.</span>
        <span>Room Management Module · Member 3</span>
      </footer>
    </div>
  </div>

  <!-- Add / Edit Room Modal -->
  <div
    class="modal fade"
    id="roomModal"
    tabindex="-1"
    aria-labelledby="roomModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content custom-modal">
        <div class="modal-header">
          <div>
            <span class="modal-kicker">ROOM MANAGEMENT</span>
            <h5 class="modal-title" id="roomModalLabel">Add New Room</h5>
          </div>
          <button
            type="button"
            class="btn-close"
            data-bs-dismiss="modal"
            aria-label="Close"
          ></button>
        </div>

        <form id="roomForm" novalidate>
          <div class="modal-body">
            <input type="hidden" id="roomId" />

            <div class="row g-3">
              <div class="col-md-6">
                <label for="roomNumber" class="form-label">Room Number</label>
                <input
                  type="text"
                  class="form-control"
                  id="roomNumber"
                  placeholder="Example: 201"
                  maxlength="8"
                  required
                />
                <div class="invalid-feedback">Enter a unique room number.</div>
              </div>

              <div class="col-md-6">
                <label for="roomType" class="form-label">Room Type</label>
                <select class="form-select" id="roomType" required>
                  <option value="">Select room type</option>
                  <option value="Standard">Standard</option>
                  <option value="Deluxe">Deluxe</option>
                  <option value="Suite">Suite</option>
                  <option value="Family">Family</option>
                </select>
                <div class="invalid-feedback">Select a room type.</div>
              </div>

              <div class="col-md-4">
                <label for="roomFloor" class="form-label">Floor</label>
                <select class="form-select" id="roomFloor" required>
                  <option value="">Select floor</option>
                  <option value="1">Floor 1</option>
                  <option value="2">Floor 2</option>
                  <option value="3">Floor 3</option>
                  <option value="4">Floor 4</option>
                </select>
                <div class="invalid-feedback">Select a floor.</div>
              </div>

              <div class="col-md-4">
                <label for="roomCapacity" class="form-label">Capacity</label>
                <input
                  type="number"
                  class="form-control"
                  id="roomCapacity"
                  min="1"
                  max="8"
                  value="2"
                  required
                />
                <div class="invalid-feedback">Capacity must be 1 to 8.</div>
              </div>

              <div class="col-md-4">
                <label for="roomRate" class="form-label">Rate per Night (LKR)</label>
                <input
                  type="number"
                  class="form-control"
                  id="roomRate"
                  min="1000"
                  step="500"
                  placeholder="18500"
                  required
                />
                <div class="invalid-feedback">Enter a valid room rate.</div>
              </div>

              <div class="col-md-6">
                <label for="roomStatus" class="form-label">Availability Status</label>
                <select class="form-select" id="roomStatus" required>
                  <option value="Available">Available</option>
                  <option value="Occupied">Occupied</option>
                  <option value="Reserved">Reserved</option>
                  <option value="Cleaning">Cleaning</option>
                  <option value="Maintenance">Maintenance</option>
                </select>
              </div>

              <div class="col-md-6">
                <label for="roomCondition" class="form-label">Room Condition</label>
                <select class="form-select" id="roomCondition" required>
                  <option value="Excellent">Excellent</option>
                  <option value="Good">Good</option>
                  <option value="Needs Inspection">Needs Inspection</option>
                  <option value="Repair Required">Repair Required</option>
                </select>
              </div>

              <div class="col-12">
                <label for="roomAmenities" class="form-label">Amenities</label>
                <input
                  type="text"
                  class="form-control"
                  id="roomAmenities"
                  placeholder="Wi-Fi, Air Conditioning, TV, Mini Bar"
                />
                <div class="form-text">
                  Separate amenities with commas.
                </div>
              </div>

              <div class="col-12">
                <label for="roomNotes" class="form-label">Internal Notes</label>
                <textarea
                  class="form-control"
                  id="roomNotes"
                  rows="3"
                  placeholder="Optional notes for reception or housekeeping..."
                ></textarea>
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-light"
              data-bs-dismiss="modal"
            >
              Cancel
            </button>
            <button type="submit" class="btn btn-gold">
              <i class="bi bi-check2-circle"></i>
              Save Room
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Status Update Modal -->
  <div
    class="modal fade"
    id="statusModal"
    tabindex="-1"
    aria-labelledby="statusModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content custom-modal">
        <div class="modal-header">
          <div>
            <span class="modal-kicker">QUICK UPDATE</span>
            <h5 class="modal-title" id="statusModalLabel">Update Room Status</h5>
          </div>
          <button
            type="button"
            class="btn-close"
            data-bs-dismiss="modal"
            aria-label="Close"
          ></button>
        </div>

        <form id="statusForm">
          <div class="modal-body">
            <input type="hidden" id="statusRoomId" />

            <div class="selected-room-panel">
              <div class="room-number-icon">
                <i class="bi bi-door-open"></i>
              </div>
              <div>
                <span>Selected Room</span>
                <strong id="selectedRoomText">Room 000</strong>
              </div>
            </div>

            <label for="quickStatus" class="form-label mt-3">New Status</label>
            <select class="form-select" id="quickStatus" required>
              <option value="Available">Available</option>
              <option value="Occupied">Occupied</option>
              <option value="Reserved">Reserved</option>
              <option value="Cleaning">Cleaning</option>
              <option value="Maintenance">Maintenance</option>
            </select>
          </div>

          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-light"
              data-bs-dismiss="modal"
            >
              Cancel
            </button>
            <button type="submit" class="btn btn-gold">
              Update Status
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div
      id="appToast"
      class="toast custom-toast"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
      <div class="toast-body">
        <i class="bi bi-check-circle-fill"></i>
        <span id="toastMessage">Room updated successfully.</span>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="js/app.js"></script>
</body>
</html>
